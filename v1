        },
        {
          id: 3,
          name: "Michael Chang",
          role: "Master Student",
          research: "Large-area Blade Coating Techniques",
          image: "https://api.dicebear.com/7.x/avataaars/svg?seed=Mike&backgroundColor=c0aede",
          email: "mike@lab.edu"
        },
        {
          id: 4,
          name: "Emily Liu",
          role: "Master Student",
          research: "Lead-free Perovskite Materials",
          image: "https://api.dicebear.com/7.x/avataaars/svg?seed=Emily&backgroundColor=d1d4f9",
          email: "emily@lab.edu"
        },
        {
          id: 5,
          name: "David Wang",
          role: "Undergraduate",
          research: "Device Fabrication Support",
