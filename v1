                        <span className="inline-block px-2 py-0.5 bg-slate-100 text-slate-600 text-xs rounded mb-1 mt-1">{member.role}</span>
                      </div>
                    </div>
                    <div className="px-6 pb-6 mt-auto">
                      <div className="border-t border-slate-100 pt-4">
