<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Home — Chieh-Ting Lin's Lab</title>
<link href="https://fonts.googleapis.com/css2?family=GFS+Didot&display=swap" rel="stylesheet">
<style>
:root{
  --teal:#294752;--teal-d:#1a2f38;--teal-l:#3d6475;
  --rose:#A8535C;--rose-l:#c4717a;
  --tuscany:#C9A84C;--tuscany-l:#e0c068;
  --white:#FFFFFF;--off:#F6F4F1;--light:#EBF0F2;
  --ink:#18282f;--muted:#6b8a92;--border:#d4e0e4;
  --font-d:'GFS Didot','Times New Roman',serif;
  --font-b:'Times New Roman',serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:var(--font-b);color:var(--ink);background:var(--white);overflow-x:hidden}
img{display:block;max-width:100%}
a{color:inherit;text-decoration:none}

/* ── NAV ── */
#navbar{
  position:fixed;top:0;left:0;right:0;z-index:200;
  padding:0 64px;height:68px;display:flex;align-items:center;
  transition:background .35s,box-shadow .35s;
}
#navbar.scrolled{
  background:rgba(255,255,255,.96);
  box-shadow:0 1px 0 var(--border);
  backdrop-filter:blur(12px);
}
#navbar.dark-hero{color:var(--white);}
#navbar.dark-hero.scrolled{color:var(--ink);}
.nav-inner{display:flex;align-items:center;justify-content:space-between;width:100%;max-width:1400px;margin:0 auto;}
.nav-logo{display:flex;align-items:center;gap:14px;font-family:var(--font-d);font-size:16px;color:inherit;}
.logo-ct{font-size:19px;color:var(--rose);font-weight:bold;}
.logo-sep{width:1px;height:20px;background:currentColor;opacity:.2;}
.nav-links{display:flex;gap:36px;list-style:none;}
.nav-links a{
  font-size:11.5px;letter-spacing:.16em;text-transform:uppercase;
  color:inherit;opacity:.75;transition:opacity .2s;
  position:relative;padding-bottom:4px;
}
.nav-links a::after{
  content:'';position:absolute;bottom:0;left:0;
  width:0;height:1.5px;background:var(--rose);transition:width .25s;
}
.nav-links a:hover{opacity:1;}
.nav-links a:hover::after,.nav-links a.active::after{width:100%;}
.nav-links a.active{opacity:1;color:var(--rose);}

/* ── HERO ── */
.hero{
  position:relative;min-height:100vh;
  background:#08131a;
  display:flex;align-items:center;overflow:hidden;
}
#hero-canvas{position:absolute;inset:0;z-index:0;}
.hero-content{
  position:relative;z-index:2;
  max-width:1200px;margin:0 auto;padding:0 64px;padding-top:100px;
}
.hero-kicker{
  font-size:11px;letter-spacing:.35em;text-transform:uppercase;
  color:rgba(255,255,255,.38);margin-bottom:24px;
  display:flex;align-items:center;gap:14px;
}
.hero-kicker::before{content:'';display:block;width:32px;height:1px;background:var(--tuscany);}
.hero-h1{
  font-family:var(--font-d);
  font-size:clamp(48px,7vw,96px);
  color:var(--white);line-height:1.0;margin-bottom:8px;
}
.hero-h1 em{color:var(--tuscany);font-style:normal;}
.hero-sub{
  font-family:var(--font-d);
  font-size:clamp(18px,2.5vw,28px);
  color:rgba(255,255,255,.38);margin-bottom:40px;font-style:italic;
}
.hero-rule{width:56px;height:2px;background:var(--rose);margin-bottom:40px;}
.hero-desc{font-size:16px;color:rgba(255,255,255,.58);max-width:520px;line-height:1.9;margin-bottom:52px;}
.hero-ctas{display:flex;gap:16px;flex-wrap:wrap;}
.btn-primary{
  font-size:12px;letter-spacing:.18em;text-transform:uppercase;
  padding:14px 32px;background:var(--rose);color:var(--white);
  transition:background .2s,transform .2s;display:inline-block;
}
.btn-primary:hover{background:var(--rose-l);transform:translateY(-2px);}
.btn-ghost{
  font-size:12px;letter-spacing:.18em;text-transform:uppercase;
  padding:14px 32px;background:transparent;color:rgba(255,255,255,.65);
  border:1.5px solid rgba(255,255,255,.18);
  transition:border-color .2s,color .2s,transform .2s;display:inline-block;
}
.btn-ghost:hover{border-color:rgba(255,255,255,.5);color:var(--white);transform:translateY(-2px);}

/* crystal legend top-right */
.crystal-legend{
  position:absolute;top:100px;right:64px;z-index:3;
  display:flex;flex-direction:column;gap:10px;
}
.cl-item{display:flex;align-items:center;gap:10px;}
.cl-dot{border-radius:50%;flex-shrink:0;}
.cl-label{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.28);}

.scroll-cue{
  position:absolute;bottom:40px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  color:rgba(255,255,255,.25);font-size:10px;letter-spacing:.25em;text-transform:uppercase;
  z-index:2;animation:bob 2.5s ease-in-out infinite;
}
@keyframes bob{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(6px)}}

/* ── STATS BAR ── */
.stats-bar{background:var(--white);border-bottom:1px solid var(--border);padding:0 64px;}
.stats-bar-inner{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:repeat(4,1fr);
  border-left:1px solid var(--border);
}
.stat-item{
  padding:38px 36px;border-right:1px solid var(--border);
  position:relative;overflow:hidden;transition:background .2s;cursor:default;
}
.stat-item:hover{background:var(--off);}
.stat-item::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--tuscany);transform:scaleX(0);transform-origin:left;transition:transform .35s;
}
.stat-item:hover::before{transform:scaleX(1);}
.stat-num{font-family:var(--font-d);font-size:44px;color:var(--teal);line-height:1;margin-bottom:6px;}
.stat-num .stat-plus{color:var(--rose);font-size:28px;}
.stat-label{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}

/* ── FIELD OF STUDY ── */
.fos-section{padding:96px 64px;background:var(--off);}
.fos-inner{max-width:1200px;margin:0 auto;}
.eyebrow{font-size:10px;letter-spacing:.3em;text-transform:uppercase;color:var(--rose);margin-bottom:14px;display:block;}
.sec-title{font-family:var(--font-d);font-size:clamp(28px,3.5vw,44px);color:var(--teal);line-height:1.1;margin-bottom:18px;}
.sec-rule{width:40px;height:2px;background:var(--tuscany);margin-bottom:52px;}

.fos-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;}
.fos-card{
  background:var(--white);padding:40px 36px;
  border:1px solid var(--border);position:relative;overflow:hidden;
  cursor:default;transition:transform .3s,box-shadow .3s;
}
.fos-card:hover{transform:translateY(-5px);box-shadow:0 16px 40px rgba(41,71,82,.1);}
.fos-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--card-color,var(--teal));
  transform:scaleX(0);transform-origin:left;transition:transform .4s;
}
.fos-card:hover::before{transform:scaleX(1);}
.fos-formula{
  font-family:var(--font-d);font-size:32px;
  color:var(--card-color,var(--teal));
  margin-bottom:16px;line-height:1;opacity:.18;
  position:absolute;top:28px;right:24px;
}
.fos-icon{font-size:28px;margin-bottom:20px;}
.fos-title{font-family:var(--font-d);font-size:18px;color:var(--teal);margin-bottom:10px;line-height:1.2;}
.fos-body{font-size:13px;color:var(--muted);line-height:1.75;}

/* ── ABOUT QUAD ── */
.about-section{padding:0 64px 0;background:var(--white);}
.about-inner{max-width:1200px;margin:0 auto;}
.about-intro-row{
  padding:80px 0 56px;
  display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:end;
  border-bottom:1px solid var(--border);
}
.about-intro-left{}
.about-intro-right{
  font-size:15px;color:var(--muted);line-height:1.9;
}

/* 2×2 quad grid — mimicking the reference image */
.about-quad{
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:auto auto;
  border-left:1px solid var(--border);
  border-top:1px solid var(--border);
}
.aq-cell{
  padding:52px 52px 56px;
  border-right:1px solid var(--border);
  border-bottom:1px solid var(--border);
  position:relative;
  transition:background .25s;
}
.aq-cell:hover{background:var(--off);}
/* Hover reveals a teal left accent */
.aq-cell::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:var(--cell-color,var(--teal));
  transform:scaleY(0);transform-origin:bottom;transition:transform .35s cubic-bezier(.22,1,.36,1);
}
.aq-cell:hover::before{transform:scaleY(1);}

.aq-title-box{
  display:inline-block;
  font-family:var(--font-d);font-size:clamp(22px,2.5vw,30px);
  color:var(--teal);
  border:1.5px solid var(--border);
  padding:10px 28px 12px;
  margin-bottom:32px;
  transition:border-color .25s;
}
.aq-cell:hover .aq-title-box{border-color:var(--cell-color,var(--teal));}

.aq-body{
  font-size:14px;color:var(--muted);line-height:1.85;
  text-align:justify;margin-bottom:28px;
}
.aq-link{
  display:inline-flex;align-items:center;gap:8px;
  font-size:11px;letter-spacing:.18em;text-transform:uppercase;
  color:var(--cell-color,var(--teal));
  opacity:0;transform:translateY(4px);
  transition:opacity .25s,transform .25s;
}
.aq-cell:hover .aq-link{opacity:1;transform:translateY(0);}
.aq-link::after{content:'→';}

/* ── PI TEASER ── */
.pi-section{padding:96px 64px;background:var(--off);}
.pi-inner{max-width:1200px;margin:0 auto;}
.pi-teaser{display:grid;grid-template-columns:300px 1fr;gap:72px;align-items:center;}
.pi-photo-frame{width:300px;aspect-ratio:3/4;position:relative;}
.pi-photo-frame::before{
  content:'';position:absolute;
  top:16px;left:16px;right:-16px;bottom:-16px;
  border:1.5px solid var(--tuscany);z-index:-1;transition:top .3s,left .3s;
}
.pi-photo-frame:hover::before{top:10px;left:10px;}
.ph{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;background:var(--light);border:1px solid var(--border);color:var(--muted);font-size:11px;letter-spacing:.15em;text-transform:uppercase;}
.ph-icon{font-size:28px;opacity:.3;}
.pi-name{font-family:var(--font-d);font-size:38px;color:var(--teal);margin-bottom:6px;}
.pi-role{font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--rose);margin-bottom:20px;}
.pi-rule{width:36px;height:2px;background:var(--tuscany);margin-bottom:24px;}
.pi-bio{font-size:15px;color:#3f5f6b;line-height:1.9;margin-bottom:32px;}

/* ── NEWS PREVIEW ── */
.news-section{padding:96px 64px;background:var(--white);}
.news-inner{max-width:1200px;margin:0 auto;}
.news-preview{display:flex;flex-direction:column;}
.np-item{
  display:grid;grid-template-columns:120px 1fr auto;
  gap:32px;align-items:start;padding:28px 0;
  border-bottom:1px solid var(--border);transition:background .2s;
}
.np-item:hover{background:var(--off);margin:0 -16px;padding:28px 16px;}
.np-date{font-size:12px;color:var(--muted);padding-top:4px;}
.np-tag{display:inline-block;font-size:9px;letter-spacing:.18em;text-transform:uppercase;padding:3px 10px;background:var(--rose);color:var(--white);margin-bottom:8px;}
.np-tag.pub{background:var(--teal);}
.np-tag.award{background:var(--tuscany);color:var(--ink);}
.np-title{font-family:var(--font-d);font-size:17px;color:var(--teal);line-height:1.35;margin-bottom:4px;}
.np-body{font-size:13px;color:var(--muted);}
.np-arrow{align-self:center;color:var(--muted);font-size:18px;opacity:0;transition:opacity .2s;}
.np-item:hover .np-arrow{opacity:1;}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);}
.reveal.visible{opacity:1;transform:translateY(0);}
.reveal-left{opacity:0;transform:translateX(-40px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);}
.reveal-left.visible{opacity:1;transform:translateX(0);}
.reveal-right{opacity:0;transform:translateX(40px);transition:opacity .7s cubic-bezier(.22,1,.36,1),transform .7s cubic-bezier(.22,1,.36,1);}
.reveal-right.visible{opacity:1;transform:translateX(0);}
.stagger-1{transition-delay:.08s}.stagger-2{transition-delay:.16s}.stagger-3{transition-delay:.24s}
.stagger-4{transition-delay:.32s}.stagger-5{transition-delay:.40s}.stagger-6{transition-delay:.48s}

/* ── FOOTER ── */
footer{background:var(--ink);padding:72px 64px 0;}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;max-width:1200px;margin:0 auto;padding-bottom:56px;border-bottom:1px solid rgba(255,255,255,.07);}
.footer-logo{font-family:var(--font-d);font-size:19px;color:var(--white);margin-bottom:14px;}
.footer-tagline{font-size:13px;color:rgba(255,255,255,.4);line-height:1.8;margin-bottom:12px;}
.footer-address{font-size:12px;color:rgba(255,255,255,.25);line-height:1.8;}
.footer-heading{font-size:9px;letter-spacing:.3em;text-transform:uppercase;color:var(--rose);margin-bottom:18px;}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:11px;}
.footer-links a{font-size:13px;color:rgba(255,255,255,.4);transition:color .2s;}
.footer-links a:hover{color:var(--white);}
.footer-bottom{max-width:1200px;margin:0 auto;display:flex;justify-content:space-between;padding:20px 0;font-size:11px;color:rgba(255,255,255,.18);letter-spacing:.06em;}
.footer-tuscany{color:var(--tuscany);opacity:.5;}
</style>
</head>
