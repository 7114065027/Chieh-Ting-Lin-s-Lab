                        <tr key={idx} className="hover:bg-slate-50"><td className="px-6 py-4">{alum.year}</td><td className="px-6 py-4">{alum.name}</td><td className="px-6 py-4 text-blue-600">{alum.destination}</td></tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </section>
          </div>
