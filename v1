                <p className="text-slate-600 text-sm mb-2">C.T. Lin et al., <span className="italic">Advanced Materials</span>, 2024.</p>
                <span className="inline-block px-2 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded">Impact Factor: 30.8</span>
              </div>
            ))}
          </div>
        </div>
      );

      // 5. Activities Placeholder
      const ActivitiesPage = () => (
        <div className="max-w-6xl mx-auto px-6 py-12 animate-in fade-in duration-500">
          <h1 className="text-4xl font-bold text-slate-900 mb-8 text-center">Lab Activities</h1>
          <div className="grid md:grid-cols-2 gap-6">
            <div className="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
              <div className="h-48 bg-purple-100 flex items-center justify-center text-purple-300"><Calendar size={48}/></div>
              <div className="p-6">
                <h3 className="font-bold text-xl mb-2">Annual MRS Meeting</h3>
                <p className="text-slate-600 text-sm">Our team presented 5 posters at the recent Material Research Society meeting in Boston.</p>
              </div>
            </div>
            <div className="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
              <div className="h-48 bg-purple-100 flex items-center justify-center text-purple-300"><Users size={48}/></div>
              <div className="p-6">
                <h3 className="font-bold text-xl mb-2">Lab Retreat 2024</h3>
                <p className="text-slate-600 text-sm">Team building and hiking trip at Yangmingshan National Park.</p>
              </div>
            </div>
          </div>
        </div>
      );


      // --- Main App Component ---
      const App = () => {
        const [currentPage, setCurrentPage] = useState('home');
        const [isMenuOpen, setIsMenuOpen] = useState(false);

        // Chatbot State
        const [isChatOpen, setIsChatOpen] = useState(false);
        const [chatMessages, setChatMessages] = useState([
          { role: 'system', content: 'Hello! I am the Lab AI Assistant. Ask me anything about our research, instruments, or members!' }
        ]);
        const [chatInput, setChatInput] = useState('');
        const [isChatLoading, setIsChatLoading] = useState(false);
        const chatEndRef = useRef(null);

        const handleChatSubmit = async (e) => {
          e.preventDefault();
          if (!chatInput.trim()) return;
          const userMsg = chatInput;
          setChatMessages(prev => [...prev, { role: 'user', content: userMsg }]);
          setChatInput('');
          setIsChatLoading(true);

          const context = `
            Lab Name: Chieh-Ting Lin Lab (Perovskite Optoelectronics)
            Current Page: ${currentPage}
            PI Data: ${JSON.stringify(piData)}
            Members: ${JSON.stringify(members.map(m => ({name: m.name, role: m.role, research: m.research})))}
            Instruments: ${JSON.stringify(instruments)}
            Mission: Advancing optoelectronic materials.
            
            Answer concise and professional.
          `;
          const aiMsg = await callGemini(userMsg, context);
          setChatMessages(prev => [...prev, { role: 'ai', content: aiMsg }]);
          setIsChatLoading(false);
        };

        useEffect(() => {
          chatEndRef.current?.scrollIntoView({ behavior: 'smooth' });
        }, [chatMessages, isChatOpen]);

        const navItems = [
          { id: 'home', label: 'Home', icon: Home },
          { id: 'members', label: 'Members', icon: Users },
          { id: 'instruments', label: 'Instruments', icon: FlaskConical },
          { id: 'publications', label: 'Publications', icon: BookOpen },
          { id: 'activities', label: 'Activities', icon: Calendar },
        ];

        return (
          <div className="min-h-screen bg-slate-50 font-sans text-slate-800 flex flex-col">
            
            {/* Navigation Bar */}
            <nav className="bg-white border-b border-slate-200 sticky top-0 z-40">
              <div className="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
                <div 
                  className="flex items-center gap-2 font-bold text-xl text-slate-900 cursor-pointer"
                  onClick={() => setCurrentPage('home')}
                >
                  <div className="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center text-white">
                    <FlaskConical size={18} />
                  </div>
                  <span>Lin Lab</span>
                </div>

                {/* Desktop Nav */}
                <div className="hidden md:flex items-center gap-1">
                  {navItems.map(item => (
                    <button
                      key={item.id}
                      onClick={() => setCurrentPage(item.id)}
                      className={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${
                        currentPage === item.id 
                          ? 'bg-blue-50 text-blue-700' 
                          : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
                      }`}
                    >
                      {item.label}
                    </button>
                  ))}
                </div>

                {/* Mobile Menu Button */}
                <button className="md:hidden p-2 text-slate-600" onClick={() => setIsMenuOpen(!isMenuOpen)}>
                  <Menu size={24} />
                </button>
              </div>

              {/* Mobile Nav */}
              {isMenuOpen && (
                <div className="md:hidden border-t border-slate-100 bg-white p-4 space-y-2">
                  {navItems.map(item => (
                    <button
                      key={item.id}
                      onClick={() => { setCurrentPage(item.id); setIsMenuOpen(false); }}
                      className={`w-full text-left px-4 py-3 rounded-lg flex items-center gap-3 text-sm font-medium ${
                        currentPage === item.id ? 'bg-blue-50 text-blue-700' : 'text-slate-600'
                      }`}
                    >
                      <item.icon size={18} /> {item.label}
                    </button>
                  ))}
                </div>
              )}
            </nav>

            {/* Main Content Area */}
            <main className="flex-1">
              {currentPage === 'home' && <HomePage setPage={setCurrentPage} />}
              {currentPage === 'members' && <MembersPage />}
              {currentPage === 'instruments' && <InstrumentsPage />}
              {currentPage === 'publications' && <PublicationsPage />}
              {currentPage === 'activities' && <ActivitiesPage />}
            </main>

            {/* Footer */}
            <footer className="bg-slate-900 text-slate-400 py-12 px-6 mt-auto">
              <div className="max-w-6xl mx-auto text-center">
                <p>&copy; 2025 Chieh-Ting Lin Lab. All rights reserved.</p>
                <p className="text-sm mt-2">Department of Materials Science and Engineering</p>
              </div>
            </footer>

            {/* Global Chatbot */}
            <div className="fixed bottom-6 right-6 z-50 flex flex-col items-end">
              {isChatOpen && (
                <div className="bg-white w-80 h-96 rounded-2xl shadow-2xl border border-slate-200 mb-4 flex flex-col overflow-hidden animate-in slide-in-from-bottom-5">
                  <div className="bg-slate-900 p-4 flex justify-between items-center text-white">
                    <div className="flex items-center gap-2">
                       <Sparkles size={16} className="text-yellow-400"/>
                       <h3 className="font-bold text-sm">Lab AI Assistant</h3>
                    </div>
                    <button onClick={() => setIsChatOpen(false)} className="hover:bg-slate-700 p-1 rounded"><X size={16}/></button>
                  </div>
                  
                  <div className="flex-1 overflow-y-auto p-4 space-y-3 bg-slate-50">
                    {chatMessages.map((msg, idx) => (
                      <div key={idx} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                        <div className={`max-w-[85%] p-3 rounded-2xl text-sm ${
                          msg.role === 'user' 
                          ? 'bg-blue-600 text-white rounded-br-none' 
                          : 'bg-white text-slate-700 border border-slate-200 shadow-sm rounded-bl-none'
                        }`}>
                          {msg.content}
                        </div>
                      </div>
                    ))}
                    {isChatLoading && (
                      <div className="flex justify-start">
                        <div className="bg-white p-3 rounded-2xl rounded-bl-none border border-slate-200 shadow-sm">
                          <Loader size={16} className="animate-spin text-blue-600"/>
                        </div>
                      </div>
                    )}
                    <div ref={chatEndRef}></div>
                  </div>

                  <form onSubmit={handleChatSubmit} className="p-3 bg-white border-t border-slate-100 flex gap-2">
                    <input 
                      type="text" 
                      value={chatInput}
                      onChange={(e) => setChatInput(e.target.value)}
                      placeholder="Ask Lab AI..."
                      className="flex-1 bg-slate-100 rounded-full px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                    />
                    <button 
                      type="submit" 
                      disabled={isChatLoading || !chatInput.trim()}
                      className="bg-blue-600 text-white p-2 rounded-full hover:bg-blue-700 disabled:opacity-50 transition-colors"
                    >
                      <Send size={16} />
                    </button>
                  </form>
                </div>
              )}

              <button 
                onClick={() => setIsChatOpen(!isChatOpen)}
                className="bg-slate-900 text-white p-4 rounded-full shadow-lg hover:bg-slate-800 transition-all hover:scale-105 group"
              >
                 {isChatOpen ? <X size={24}/> : <MessageSquare size={24} />}
              </button>
            </div>

          </div>
        );
      };

      // 5. 渲染 App
      const root = createRoot(document.getElementById('root'));
      root.render(<App />);
      
      // 顯示頁面
      document.body.classList.add('loaded');
    </script>
  </body>
</html>
