        <a href="instruments.html" class="aq-link">View Instruments</a>
      </div>
    </div>
  </div>
</div>

<!-- PI TEASER -->
<div class="pi-section">
  <div class="pi-inner">
    <span class="eyebrow reveal">Principal Investigator</span>
    <h2 class="sec-title reveal">Meet the PI</h2>
    <div class="sec-rule reveal"></div>
    <div class="pi-teaser">
      <div class="pi-photo-frame reveal-left">
        <div class="ph" style="width:300px;height:400px;">
          <span class="ph-icon">👤</span><span>PI Photo</span>
        </div>
