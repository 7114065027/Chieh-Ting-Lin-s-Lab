        { name: "Glovebox System", desc: "Nitrogen-filled environment for sensitive material handling." },
        { name: "Thermal Evaporator", desc: "High-vacuum deposition for metal electrodes." },
        { name: "Spin Coater", desc: "Precise thin-film deposition control." }
      ];

      const highlights = [
        {
          id: 1,
          title: "High-Efficiency Solar Cells",
          desc: "Achieving 25% efficiency in perovskite solar cells through novel interface engineering.",
          image: "https://images.unsplash.com/photo-1509391366360-2e959784a276?w=800&auto=format&fit=crop&q=60" 
        },
        {
          id: 2,
