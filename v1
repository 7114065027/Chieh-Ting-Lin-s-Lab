      const alumni = [
        { year: "2023", name: "Dr. John Doe", thesis: "High Performance PVs", destination: "R&D Engineer at TSMC" },
        { year: "2022", name: "Jane Smith", thesis: "Quantum Dot Synthesis", destination: "Postdoc at MIT" },
