          </section>

          <section className="max-w-6xl mx-auto px-6 py-20">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
              <div 
                onClick={() => setPage('publications')}
                className="group bg-white p-8 rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-blue-300 transition-all cursor-pointer flex flex-col items-center text-center"
              >
                <div className="w-16 h-16 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                  <BookOpen size={32} />
                </div>
                <h3 className="text-2xl font-bold text-slate-900 mb-3">Publications</h3>
                <p className="text-slate-600">Published in top-tier journals, our work spans material science and optoelectronics.</p>
              </div>

              <div 
                onClick={() => setPage('members')}
                className="group bg-white p-8 rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-blue-300 transition-all cursor-pointer flex flex-col items-center text-center"
              >
                <div className="w-16 h-16 bg-green-50 text-green-600 rounded-full flex items-center justify-center mb-6 group-hover:bg-green-600 group-hover:text-white transition-colors">
                  <Users size={32} />
                </div>
                <h3 className="text-2xl font-bold text-slate-900 mb-3">Members</h3>
                <p className="text-slate-600">A passionate team dedicated to pushing the boundaries of material synthesis.</p>
              </div>

              <div 
                onClick={() => setPage('activities')}
                className="group bg-white p-8 rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-blue-300 transition-all cursor-pointer flex flex-col items-center text-center"
              >
                <div className="w-16 h-16 bg-purple-50 text-purple-600 rounded-full flex items-center justify-center mb-6 group-hover:bg-purple-600 group-hover:text-white transition-colors">
                  <Calendar size={32} />
                </div>
                <h3 className="text-2xl font-bold text-slate-900 mb-3">Activities</h3>
                <p className="text-slate-600">We host regular seminars and academic events to foster intellectual exchange.</p>
              </div>

              <div 
                onClick={() => setPage('instruments')}
                className="group bg-white p-8 rounded-2xl border border-slate-200 shadow-sm hover:shadow-xl hover:border-blue-300 transition-all cursor-pointer flex flex-col items-center text-center"
              >
                <div className="w-16 h-16 bg-orange-50 text-orange-600 rounded-full flex items-center justify-center mb-6 group-hover:bg-orange-600 group-hover:text-white transition-colors">
                  <Microscope size={32} />
                </div>
                <h3 className="text-2xl font-bold text-slate-900 mb-3">Instruments</h3>
                <p className="text-slate-600">Equipped with state-of-the-art fabrication and characterization tools.</p>
              </div>

            </div>
          </section>
        </div>
      );

      // 2. Members Page Component
      const MembersPage = () => {
        const [activeTab, setActiveTab] = useState('All');
        const [explainingId, setExplainingId] = useState(null);
        const [explanations, setExplanations] = useState({});

        const handleExplainResearch = async (memberId, researchTopic) => {
          if (explanations[memberId]) return;
          setExplainingId(memberId);
          const prompt = `Explain the research topic "${researchTopic}" simply in one short sentence for a high school student. Focus on why it's cool or useful. (Keep it under 25 words).`;
          const result = await callGemini(prompt);
          setExplanations(prev => ({ ...prev, [memberId]: result }));
          setExplainingId(null);
        };

        const filterTabs = ['All', 'Ph.D. Student', 'Master Student', 'Undergraduate'];
        const filteredMembers = activeTab === 'All' ? members : members.filter(m => m.role === activeTab);

        return (
          <div className="max-w-6xl mx-auto px-6 py-12 space-y-20 animate-in fade-in duration-500">
            
            <section>
              <div className="flex items-center gap-2 mb-8">
                <div className="w-1 h-8 bg-blue-600 rounded-full"></div>
                <h2 className="text-2xl font-bold text-slate-900">Principal Investigator</h2>
              </div>
              <div className="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden flex flex-col md:flex-row">
                <div className="md:w-1/3 bg-slate-100 flex items-center justify-center p-8 relative overflow-hidden">
                   <div className="w-48 h-48 md:w-56 md:h-56 rounded-full bg-white border-4 border-white shadow-lg overflow-hidden relative z-10">
                     <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Prof&backgroundColor=e5e7eb" alt="Professor" className="w-full h-full object-cover" />
                   </div>
                   <div className="absolute inset-0 bg-gradient-to-br from-blue-50 to-slate-200 opacity-50"></div>
                </div>
                <div className="md:w-2/3 p-8 md:p-10 flex flex-col justify-center">
                  <h3 className="text-3xl font-bold text-slate-900 mb-2">{piData.name}</h3>
                  <p className="text-blue-600 font-medium text-lg mb-4">{piData.title}</p>
                  <p className="text-slate-600 leading-relaxed mb-6">{piData.bio}</p>
                  <div className="flex flex-wrap gap-4 text-sm text-slate-500 mb-6">
                    <span className="flex items-center gap-1"><Mail size={16} /> {piData.email}</span>
                    <span className="flex items-center gap-1"><MapPin size={16} /> {piData.location}</span>
                  </div>
                  <div className="flex flex-wrap gap-2">
                    {piData.interests.map((tag, idx) => (
